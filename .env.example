OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
WORLD_LENS_DB_PATH=./data/world_lens.sqlite
RESEARCH_COUNTRY_LIMIT=20
# 同時に調査する国数(1-8)。上げると速いがレート制限に注意
RESEARCH_CONCURRENCY=3
# web_search の検索コンテキスト量: low | medium | high (コストと精度のトレードオフ)
RESEARCH_SEARCH_CONTEXT=medium
# 毎日この時刻(ローカル時間 HH:MM)に自動でリサーチを実行。空なら無効
RESEARCH_AUTO_TIME=
PORT=8787
